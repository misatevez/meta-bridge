# --- Meta App credentials (provided by client / Architect custody) ---
META_APP_ID=
META_APP_SECRET=
# Random opaque string we send to Meta when configuring the webhook URL.
# Meta echoes it back in the GET verification handshake. Generate with:
#   openssl rand -hex 32
META_VERIFY_TOKEN=

# --- SuiteCRM API V8 OAuth2 client (created in Sprint 2 A2) ---
SUITECRM_BASE_URL=https://firmas.moacrm.com
SUITECRM_OAUTH_CLIENT_ID=
SUITECRM_OAUTH_CLIENT_SECRET=

# --- MariaDB OCI managed (database `meta_bridge`) ---
DB_HOST=129.213.101.91
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=meta_bridge

# --- MariaDB firmascrm (for SuiteCRM meta_conversations + meta_messages sync) ---
# Defaults to same host/port as DB_HOST/DB_PORT if not set
FIRMASCRM_DB_HOST=129.213.101.91
FIRMASCRM_DB_PORT=3306
FIRMASCRM_DB_USER=meta_bridge
FIRMASCRM_DB_PASS=
FIRMASCRM_DB_NAME=firmascrm

# --- Server ---
# In production behind Apache reverse proxy, bind only to loopback so the bridge
# is not directly reachable on :3000 from the internet. Override to 0.0.0.0
# only for local dev/testing.
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
