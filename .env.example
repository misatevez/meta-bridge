# --- Meta App credentials (provided by client / Architect custody) ---
META_APP_ID=
META_APP_SECRET=
# Random opaque string we send to Meta when configuring the webhook URL.
# Meta echoes it back in the GET verification handshake. Generate with:
#   openssl rand -hex 32
META_VERIFY_TOKEN=

# --- SuiteCRM API V8 OAuth2 client (created in Sprint 2 A2) ---
SUITECRM_BASE_URL=https://firmas.moacrm.com
SUITECRM_OAUTH_CLIENT_ID=
SUITECRM_OAUTH_CLIENT_SECRET=

# --- MariaDB OCI managed (database `meta_bridge`) ---
DB_HOST=129.213.101.91
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=meta_bridge

# --- Server ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
