# Logrotate configuration for PM2 meta-bridge process logs
# Installation: sudo cp meta-bridge /etc/logrotate.d/meta-bridge
# Test: sudo logrotate -d /etc/logrotate.d/meta-bridge (dry-run)
# Force rotation: sudo logrotate -f /etc/logrotate.d/meta-bridge

/home/ubuntu/.pm2/logs/meta-bridge-out.log
/home/ubuntu/.pm2/logs/meta-bridge-error.log
{
    daily
    rotate 14
    compress
    missingok
    notifempty
    copytruncate
}
